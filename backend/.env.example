# Translation provider: "gemini" (default) or "openrouter"
TRANSLATE_PROVIDER=gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash-lite

# Required only when TRANSLATE_PROVIDER=openrouter
# Get free API key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free  # default

# VieNeu TTS mode: "local" (default) or "remote"
VIENEU_MODE=local

# Required only when VIENEU_MODE=remote
# VIENEU_API_BASE=http://localhost:23333/v1
# VIENEU_MODEL_NAME=pnnbao-ump/VieNeu-TTS
